# Database
DATABASE_URL=postgresql://healz:healz_dev@localhost:5432/healz_dev
# Set to "true" when connecting to a cloud database (e.g. Render, Supabase) that requires SSL
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3001
NODE_ENV=development

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/v1/auth/google-calendar/callback

# Encryption (AES-256-GCM) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
